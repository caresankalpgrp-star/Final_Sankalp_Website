{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)",    "destination": "/api/$1"      },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/robots.txt",  "destination": "/api/robots"  },
    { "source": "/(.*)",        "destination": "/index.html"  }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*"                            },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS"  },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL":      "https://jhrfnnnvivyyjzywnvse.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable__jKUC5tRXSijAYsdXyT1Uw_iiOfXl8J",
    "SUPABASE_SERVICE_ROLE_KEY":     "sb_secret_wH7BY79yCUaCs1asbAXh9w_EUU7oXhw",
    "VITE_SUPABASE_URL":             "https://jhrfnnnvivyyjzywnvse.supabase.co",
    "VITE_SUPABASE_ANON_KEY":        "sb_publishable__jKUC5tRXSijAYsdXyT1Uw_iiOfXl8J"
  }
}
